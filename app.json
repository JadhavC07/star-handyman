{
  "expo": {
    "name": "starhandyman-pro",
    "slug": "starhandyman-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "starhandymanpro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "StarHandyman uses the camera so you can take a profile photo.",
        "NSMicrophoneUsageDescription": "StarHandyman does not record audio; this permission is requested by the camera module."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.starhandyman.pro",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-firebase/app",
      [
        "@react-native-firebase/messaging",
        {
          "android": {
            "icon": "./assets/images/notification-icon.png",
            "color": "#FF6B00"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "cameraPermission": "StarHandyman uses the camera so you can take a profile photo.",
          "photosPermission": "StarHandyman accesses your photos so you can upload license documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6d2f21e-3f1b-476e-bc9d-4465b1bd42dc"
      }
    }
  }
}
